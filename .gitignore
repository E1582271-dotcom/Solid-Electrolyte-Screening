# secrets — never commit
mp_api_key.txt
*.key

# OBELiX data — auto-downloaded on first run, not redistributed (respects its license).
# Keep our own reproducible JSONs tracked (mirror Project 2's data/metrics.json).
data/*
!data/metrics.json
!data/uncertainty.json

# trained model weight — regenerated by 01_train_eval.py (mirrors Project 2's *.model/*.pth)
*.cbm
# CatBoost training-log dir (written on every fit)
catboost_info/

# screen demo output (regenerated by 04_screen_mp.py --demo)
screen_demo.csv
# NOTE: screen_mp_results.csv IS shipped (below, as static data) — 05_screen_audit_figures.py
# reads it to regenerate Figs 6-7 offline, since a live MP re-query needs an API key.

# Python
__pycache__/
*.pyc
.venv/
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db
